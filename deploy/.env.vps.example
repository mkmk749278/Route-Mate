APP_ENV=production
API_PORT=3000
JWT_EXPIRES_IN=7d

DB_NAME=route_mates
DB_USER=route_mates
DB_PASSWORD=replace_with_secure_db_password

JWT_SECRET=replace_with_a_secure_jwt_secret_min_16_chars

# Leave blank only if allow-all CORS is intentionally desired.
# Prefer setting this to your app/web origin(s), comma-separated if needed.
CORS_ORIGIN=
