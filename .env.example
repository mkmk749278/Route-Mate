APP_ENV=development

API_PORT=3000

# Host-local DB values (API runs on host machine)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=route_mates
DB_USER=route_mates
DB_PASSWORD=route_mates
DATABASE_URL=postgresql://route_mates:route_mates@localhost:5432/route_mates
# Docker Compose API container URL alternative:
# DATABASE_URL=postgresql://route_mates:route_mates@postgres:5432/route_mates

# Host-local Redis values (API runs on host machine)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# Docker Compose API container URL alternative:
# REDIS_URL=redis://redis:6379

JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=7d
