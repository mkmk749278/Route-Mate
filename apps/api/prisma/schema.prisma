// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  email             String   @unique
  name              String
  passwordHash      String
  phone             String?
  city              String?
  gender            String?
  bio               String?
  avatarUrl         String?
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  routePosts        RoutePost[]
  outgoingRouteInterests RouteInterest[] @relation("RouteInterestRequester")
  incomingRouteInterests RouteInterest[] @relation("RouteInterestOwner")
}

model RoutePost {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @db.Uuid
  origin                 String
  destination            String
  travelDate             DateTime
  preferredDepartureTime String
  seatCount              Int?
  notes                  String?
  status                 String   @default("active")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeInterests         RouteInterest[]

  @@index([userId, createdAt])
}

model RouteInterest {
  id              String   @id @default(uuid()) @db.Uuid
  routePostId     String   @db.Uuid
  requesterUserId String   @db.Uuid
  ownerUserId     String   @db.Uuid
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  routePost       RoutePost @relation(fields: [routePostId], references: [id], onDelete: Cascade)
  requester       User      @relation("RouteInterestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  owner           User      @relation("RouteInterestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
  @@index([requesterUserId, createdAt])
  @@index([routePostId, requesterUserId, status])
}
